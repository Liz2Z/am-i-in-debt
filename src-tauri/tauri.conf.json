{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Am I In Debt",
  "version": "1.0.0",
  "identifier": "com.am-i-in-debt.app",
  "build": {
    "beforeDevCommand": "bun run build:sidecar",
    "beforeBuildCommand": "bun run build:sidecar"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/get-cookies"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "./entitlements.plist"
    }
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'"
    }
  }
}
